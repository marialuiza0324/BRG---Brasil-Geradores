//Bibliotecas
#Include "Totvs.ch"
#Include "RESTFul.ch"
#Include "TopConn.ch"

/*/{Protheus.doc} WSRESTFUL WSCON002
Serviþo REST para consulta de rateios
@author Maria Luiza
@since 17/07/2026
@version 1.0
@type wsrestful
/*/

WSRESTFUL WSCON002 DESCRIPTION 'Serviþo REST para consulta de rateios'
	//Atributos
	WSDATA updated_at AS STRING
	WSDATA limit      AS INTEGER
	WSDATA page       AS INTEGER

	//MÚtodos
	WSMETHOD GET    ALL    DESCRIPTION 'Retorna todos os registros'    WSSYNTAX '/WSCON002/get_all?{updated_at, limit, page}' PATH 'get_all'       PRODUCES APPLICATION_JSON
END WSRESTFUL

/*/{Protheus.doc} WSMETHOD GET ALL
Busca todos os registros atravÚs de paginaþÒo
@author Maria Luiza
@since 17/07/2026
@version 1.0
@type method
@param updated_at, Caractere, Data de alteraþÒo no formato string 'YYYY-MM-DD' (somente se tiver o campo USERLGA / USERGA na tabela)
@param limit, NumÚrico, Limite de registros que irß vir (por exemplo trazer apenas 100 registros)
@param page, NumÚrico, N·mero da pßgina que irß buscar (se existir 1000 registros dividido por 100 terß 10 pßginas de pesquisa)
@obs Codigo gerado automaticamente pelo Autumn Code Maker

    Poderia ser usado o FWAdapterBaseV2(), mas em algumas vers§es antigas nÒo existe essa funcionalidade
    entÒo a paginaþÒo foi feita manualmente
/*/

WSMETHOD GET ALL WSRECEIVE updated_at, limit, page WSSERVICE WSCON002
	Local lRet       := .T.
	Local jResponse  := JsonObject():New()
	Local cQueryTab  := ''
	Local nTamanho   := 10
	Local nTotal     := 0
	Local nPags      := 0
	Local nPagina    := 0
	Local nAtual     := 0
	Local oRegistro
	Local jJsonMeta

	cQueryTab := "SELECT Concat(CTJ.CTJ_FILIAL, '-' , M0_FILIAL) AS Filial, " + CRLF
	cQueryTab += "Concat(CTJ.CTJ_RATEIO, '-', CTJ.CTJ_DESC) AS Rateio,  " + CRLF
	cQueryTab += " CTJ.CTJ_SEQUEN AS Sequencia, " + CRLF
	cQueryTab += " CTJ.CTJ_PERCEN AS Percentual, " + CRLF
	cQueryTab += " CTJ.CTJ_CCD AS CentroCustoDebito, " + CRLF
	cQueryTab += " CTJ.CTJ_CCC AS CentroCustoCredito, " + CRLF
	cQueryTab += " CTJ.CTJ_DEBITO AS ContaDebito, " + CRLF
	cQueryTab += " CTJ.CTJ_CREDIT AS ContaCredito " + CRLF
	cQueryTab += " FROM CTJ010 CTJ " + CRLF
	cQueryTab += " LEFT JOIN SYS_COMPANY SM0 " + CRLF
	cQueryTab += " ON SM0.M0_CODFIL = CTJ.CTJ_FILIAL " + CRLF
	cQueryTab += " WHERE CTJ.D_E_L_E_T_  = '' " + CRLF
	cQueryTab += " AND SM0.M0_CODIGO = '01' " + CRLF
	cQueryTab += " ORDER BY CTJ.CTJ_RATEIO " + CRLF

	TCQuery cQueryTab New Alias 'QRY_TAB'

	//Se nÒo encontrar registros
	If QRY_TAB->(EoF())
		//SetRestFault(500, 'Falha ao consultar registros') //caso queira usar esse comando, vocÛ nÒo poderß usar outros retornos, como os abaixo
		Self:setStatus(500)
		jResponse['errorId']  := 'ALL003'
		jResponse['error']    := 'Registro(s) nÒo encontrado(s)'
		jResponse['solution'] := 'A consulta de registros nÒo retornou nenhuma informaþÒo'
	Else
		jResponse['objects'] := {}

		//Conta o total de registros
		Count To nTotal
		QRY_TAB->(DbGoTop())

		 /*
            Regra:
            - Se vier limit informado, pagina normalmente
            - Se nÒo vier limit, retorna todos os registros
        */
		If !Empty(::limit) .And. ::limit > 0
			nTamanho := ::limit
		Else
			nTamanho := nTotal
		EndIf

		If nTamanho <= 0
			nTamanho := 1
		EndIf

		//Calcula total de pßginas
		nPags := Int(nTotal / nTamanho)
		nPags += Iif(nTotal % nTamanho <> 0, 1, 0)

		If nPags <= 0
			nPags := 1
		EndIf

        /*
            S¾ pagina se limit foi informado.
            Sem limit, retorna tudo.
        */
		If !Empty(::limit) .And. ::limit > 0
			If !Empty(::page)
				nPagina := ::page
			EndIf

			If nPagina <= 0 .Or. nPagina > nPags
				nPagina := 1
			EndIf

			If nPagina <> 1
				QRY_TAB->(DbSkip((nPagina - 1) * nTamanho))
			EndIf
		Else
			nPagina := 1
		EndIf

		//Adiciona os dados para a meta
		jJsonMeta := JsonObject():New()
		jJsonMeta['total']         := nTotal
		jJsonMeta['current_page']  := nPagina
		jJsonMeta['total_page']    := nPags
		jJsonMeta['total_items']   := nTamanho
		jResponse['meta'] := jJsonMeta

		//Percorre os registros
		While ! QRY_TAB->(EoF())
			nAtual++

			//Se ultrapassar o limite, encerra o laþo
			If nAtual > nTamanho
				Exit
			EndIf

			oRegistro := JsonObject():New()
			oRegistro['Filial'] := AllTrim(QRY_TAB->Filial)
			oRegistro['Rateio'] := AllTrim(QRY_TAB->Rateio)
			oRegistro['Sequencia'] := AllTrim(QRY_TAB->Sequencia)
			oRegistro['Percentual'] := QRY_TAB->Percentual
			oRegistro['CentroCustoDebito'] := AllTrim(QRY_TAB->CentroCustoDebito)
			oRegistro['CentroCustoCredito'] := AllTrim(QRY_TAB->CentroCustoCredito)
			oRegistro['ContaDebito'] := AllTrim(QRY_TAB->ContaDebito)
			oRegistro['ContaCredito'] := AllTrim(QRY_TAB->ContaCredito)
			aAdd(jResponse['objects'], oRegistro)

			QRY_TAB->(DbSkip())
		EndDo
	EndIf
	QRY_TAB->(DbCloseArea())

	//Define o retorno
	Self:SetContentType('application/json')
	Self:SetResponse(EncodeUTF8(jResponse:toJSON()))

Return lRet
